# ─── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
# Full connection string from Atlas: Settings → Connect → Drivers
MONGODB_URI=mongodb+srv://rohitcpp0777_db_user:Rohit12345@cluster0.he655rm.mongodb.net/complaintsDB

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-min-64-chars
JWT_EXPIRES_IN=7d

# ─── Gemini AI ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro

# ─── File Storage ────────────────────────────────────────────────────────────
# For production: replace with S3/GCS credentials
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── Frontend (CORS) ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── SLA Cron ────────────────────────────────────────────────────────────────
# How often the SLA checker runs (cron expression)
SLA_CRON_SCHEDULE=*/5 * * * *
